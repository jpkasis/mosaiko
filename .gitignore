# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Live Shopify secrets (Client ID/Secret, transitional admin token, variant GIDs)
ShopifyValues.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# product image backups
public/products/_originals/

# dev-mode cart-composite blob cache (filesystem-backed; survives dev-server
# restart so cart thumbnails remain valid). Production uses R2; this dir is
# only written when R2 is unreachable.
/.cart-composite-cache/
